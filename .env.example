# LLM provider — OpenAI-compatible client, provider switched by config, not code (Decision 3).
# Dev = DeepSeek, delivery = OpenAI. Consumed by agent/client.py (the only module that knows
# providers exist). LLM_BASE_URL / LLM_MODEL are optional — each provider has defaults in the
# client; switching provider = change LLM_PROVIDER + LLM_API_KEY.
LLM_PROVIDER=deepseek
LLM_API_KEY=your-api-key-here
# LLM_BASE_URL=            # optional override; defaults per provider
# LLM_MODEL=               # optional override; defaults per provider
