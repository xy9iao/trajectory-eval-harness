# Model provider for the agent-under-test (OpenAI). See src/config.py for the factory.
OPENAI_API_KEY=sk-...
# Optional: route through a gateway/proxy. Leave unset for api.openai.com.
# OPENAI_BASE_URL=

# Default model the agent uses (classify / gather_context / decide_action).
MODEL=gpt-4o-mini
# Fixed judge model for LLM-as-judge final-answer scoring (GUIDE §6.2 #8). Keep it fixed across a study.
JUDGE_MODEL=gpt-4o
